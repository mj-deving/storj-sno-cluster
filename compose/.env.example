# Storj SNO compose template, environment variables
# Copy to .env and fill with operator-specific values
# .env is .gitignored; never commit a populated copy

# ============================================================
# Operator identity
# ============================================================

# Wallet that receives STORJ token payouts (ERC-20 / zkSync / Polygon)
# Resolve before generating identity; cannot change post-authorization
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Operator email for storj notifications (vetting status, suspension warnings)
OPERATOR_EMAIL=operator@example.com

# ============================================================
# Host UID/GID (rootless docker; non-root operator owns identity files)
# ============================================================

UID=1000
GID=1000

# ============================================================
# Wireguard / Tailscale interface IP on which node-exporter binds
# Never 0.0.0.0; see HARDENING.md
# ============================================================

WG_INTERFACE_IP=10.0.0.1

# ============================================================
# Node 1
# ============================================================

# Public address that satellites advertise (static IP or DDNS)
NODE_ADDRESS_1=node1.example.com

# External port forwarded to this node (unique per node behind one NAT)
NODE_PORT_1=28967

# Storage allocation, capped below physical disk size (leave 10% headroom)
STORAGE_ALLOCATION_1=2TB

# Host directories (bind-mounted into container)
IDENTITY_DIR_1=/opt/storj/identity-1
STORAGE_DIR_1=/opt/storj/storage-1

# Loopback ports for dashboard and debug (operator-mesh only)
DASHBOARD_PORT_1=14002
DEBUG_PORT_1=5999

# ============================================================
# Node 2
# ============================================================

NODE_ADDRESS_2=node2.example.com
NODE_PORT_2=28968
STORAGE_ALLOCATION_2=2TB
IDENTITY_DIR_2=/opt/storj/identity-2
STORAGE_DIR_2=/opt/storj/storage-2
DASHBOARD_PORT_2=14003
DEBUG_PORT_2=6000

# ============================================================
# Add Node 3..10 by duplicating the block above and bumping the suffix
# Each node needs a unique NODE_PORT, IDENTITY_DIR, STORAGE_DIR,
# DASHBOARD_PORT, and DEBUG_PORT
# ============================================================
