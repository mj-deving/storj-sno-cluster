{
  "annotations": {
    "list": []
  },
  "description": "Storj SNO reference dashboard. Template only. Replace every <PLACEHOLDER> with operator-specific values before use. Metric names depend on the storagenode version; verify against /metrics output.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "<PROMETHEUS_DATASOURCE_UID>"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "up{job=\"storagenode\", instance=\"<NODE_INSTANCE>\"}",
          "legendFormat": "<NODE_ID>",
          "refId": "A"
        }
      ],
      "title": "Uptime (per node)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "rate(<STORJ_INGRESS_BYTES_METRIC>{instance=\"<NODE_INSTANCE>\"}[5m])",
          "legendFormat": "ingress <NODE_ID>",
          "refId": "A"
        }
      ],
      "title": "Ingress traffic",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "rate(<STORJ_EGRESS_BYTES_METRIC>{instance=\"<NODE_INSTANCE>\"}[5m])",
          "legendFormat": "egress <NODE_ID>",
          "refId": "A"
        }
      ],
      "title": "Egress traffic (revenue driver)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "<STORJ_AUDIT_SCORE_METRIC>{instance=\"<NODE_INSTANCE>\"}",
          "legendFormat": "<SATELLITE_ID>",
          "refId": "A"
        }
      ],
      "title": "Audit score (per satellite)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "<STORJ_SUSPENSION_SCORE_METRIC>{instance=\"<NODE_INSTANCE>\"}",
          "legendFormat": "<SATELLITE_ID>",
          "refId": "A"
        }
      ],
      "title": "Suspension score (per satellite)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "<PROMETHEUS_DATASOURCE_UID>" },
          "expr": "<STORJ_DISK_USED_METRIC> / <STORJ_DISK_ALLOCATED_METRIC>",
          "legendFormat": "<NODE_ID>",
          "refId": "A"
        }
      ],
      "title": "Disk utilisation (per node)",
      "type": "bargauge"
    }
  ],
  "refresh": "<EXAMPLE_REFRESH_INTERVAL>",
  "schemaVersion": 39,
  "tags": ["storj", "sno", "reference", "template"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "<OPERATOR_TIMEZONE>",
  "title": "Storj SNO reference dashboard (template)",
  "uid": "<DASHBOARD_UID>",
  "version": 1,
  "weekStart": ""
}
